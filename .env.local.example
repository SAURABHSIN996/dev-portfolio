# Strapi CMS
STRAPI_URL=https://your-strapi.railway.app
STRAPI_API_TOKEN=your_strapi_api_token
STRAPI_WEBHOOK_SECRET=your_random_secret_string

# Public base URL (used for sitemap and RSS)
NEXT_PUBLIC_BASE_URL=https://yoursite.com

# Analytics (Umami) — optional
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id

# Giscus (comments) — optional
NEXT_PUBLIC_GISCUS_REPO=your-github-username/your-repo
NEXT_PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxx
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxx
